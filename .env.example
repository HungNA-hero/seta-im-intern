# Shared local environment for seta-dam
# Copy to .env at repo root. Consumed by:
#   - docker compose  (via the infra/.env symlink -> ../.env)
#   - access-core      (dotenv, loads repo-root .env)
#   - asset-core       (godotenv, loads repo-root .env)
#
# PORT is intentionally omitted: asset-core defaults to 8080 and
# access-core to 4000, so a single shared PORT would collide.

# --- asset_db / asset-core ---
ASSET_DB_HOST=localhost
ASSET_DB_PORT=5433
ASSET_DB_NAME=asset_db
ASSET_DB_USER=asset_user
ASSET_DB_PASSWORD=asset_password
ASSET_DB_SSLMODE=disable

# --- access_db / access-core ---
ACCESS_DB_HOST=localhost
ACCESS_DB_PORT=5434
ACCESS_DB_NAME=access_db
ACCESS_DB_USER=access_user
ACCESS_DB_PASSWORD=access_password

# --- access-core service ---
HOST=0.0.0.0
GO_ASSET_URL=http://localhost:8080

# --- host-published port for the access-core container (compose only) ---
NODE_ACCESS_CORE_PORT=4000
