      "type": "table",
      "name": "organizations",
      "filePath": "infra/db/access/migrations/V1__create_access_schema.sql",
      "summary": "Đại diện tenant tổ chức với mã và tên duy nhất, đồng thời lưu cờ bật tính năng OLP. Các check constraint ngăn mã hoặc tên rỗng.",
      "tags": [
        "tổ-chức",
        "multi-tenant",
        "cấu-hình",
        "postgresql"
      ],
      "complexity": "simple"
    },
