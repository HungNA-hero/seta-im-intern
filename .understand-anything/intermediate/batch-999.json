    },
    {
      "id": "table:infra/db/access/migrations/V1__create_access_schema.sql:roles",
      "type": "table",
      "name": "roles",
      "filePath": "infra/db/access/migrations/V1__create_access_schema.sql",
      "summary": "Định nghĩa vai trò trong phạm vi từng tổ chức, với mã vai trò duy nhất theo tenant. Khóa duy nhất ghép `id` và `org_id` hỗ trợ foreign key bảo toàn phạm vi tổ chức.",
      "tags": [
        "vai-trò",
