generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  schemas  = ["access"]
}

enum PermissionActionCode {
  read
  write
  delete
  manage_permissions

  @@map("permission_action_code")
  @@schema("access")
}

enum ResourceType {
  folder
  metadata_item

  @@map("resource_type")
  @@schema("access")
}

model User {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email       String    @unique
  displayName String    @map("display_name")
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime  @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  orgMembers        OrganizationMember[]
  userRoles         UserRole[]
  grantedPerms      ObjectPermission[]   @relation("GrantedBy")
  objectPermissions ObjectPermission[]   @relation("GranteeUser")

  @@map("users")
  @@schema("access")
}

model Organization {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code       String   @unique
  name       String
  olpEnabled Boolean  @default(false) @map("olp_enabled")
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt  DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  members           OrganizationMember[]
  roles             Role[]
  userRoles         UserRole[]
  objectPermissions ObjectPermission[]

  @@map("organizations")
  @@schema("access")
}

model OrganizationMember {
  id       String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId    String   @map("org_id") @db.Uuid
  userId   String   @map("user_id") @db.Uuid
  joinedAt DateTime @default(now()) @map("joined_at") @db.Timestamptz(6)

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@map("organization_members")
  @@schema("access")
}

model Role {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId       String   @map("org_id") @db.Uuid
  code        String
  name        String
  description String?
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt   DateTime @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)

  org               Organization       @relation(fields: [orgId], references: [id], onDelete: Cascade)
  userRoles         UserRole[]
  rolePermissions   RolePermission[]
  objectPermissions ObjectPermission[]

  @@unique([orgId, code])
  @@map("roles")
  @@schema("access")
}

model UserRole {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String   @map("org_id") @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  roleId     String   @map("role_id") @db.Uuid
  assignedAt DateTime @default(now()) @map("assigned_at") @db.Timestamptz(6)

  org  Organization @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role         @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId, roleId])
  @@map("user_roles")
  @@schema("access")
}

model PermissionAction {
  id          String               @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  code        PermissionActionCode @unique
  description String?

  rolePermissions   RolePermission[]
  objectPermissions ObjectPermission[]

  @@map("permission_actions")
  @@schema("access")
}

model RolePermission {
  id           String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  roleId       String       @map("role_id") @db.Uuid
  actionId     String       @map("action_id") @db.Uuid
  resourceType ResourceType @map("resource_type")

  role   Role             @relation(fields: [roleId], references: [id], onDelete: Cascade)
  action PermissionAction @relation(fields: [actionId], references: [id], onDelete: Cascade)

  @@unique([roleId, actionId, resourceType])
  @@map("role_permissions")
  @@schema("access")
}

model ObjectPermission {
  id            String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String       @map("org_id") @db.Uuid
  resourceType  ResourceType @map("resource_type")
  resourceId    String       @map("resource_id") @db.Uuid
  granteeUserId String?      @map("grantee_user_id") @db.Uuid
  granteeRoleId String?      @map("grantee_role_id") @db.Uuid
  actionId      String       @map("action_id") @db.Uuid
  grantedBy     String       @map("granted_by") @db.Uuid
  grantedAt     DateTime     @default(now()) @map("granted_at") @db.Timestamptz(6)

  org     Organization     @relation(fields: [orgId], references: [id], onDelete: Cascade)
  grantee User?            @relation("GranteeUser", fields: [granteeUserId], references: [id], onDelete: Cascade)
  grantor User             @relation("GrantedBy", fields: [grantedBy], references: [id])
  action  PermissionAction @relation(fields: [actionId], references: [id], onDelete: Cascade)
  role    Role?            @relation(fields: [granteeRoleId], references: [id], onDelete: Cascade)

  @@map("object_permissions")
  @@schema("access")
}
