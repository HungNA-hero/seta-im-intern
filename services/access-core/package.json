{
  "name": "node-access-core",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "tsx watch --clear-screen=false src/index.ts",
    "build": "tsc",
    "lint": "tsc --noEmit",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:migrate": "prisma migrate deploy",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@prisma/adapter-pg": "^7.8.0",
    "@prisma/client": "^7.8.0",
    "dotenv": "^17.4.2",
    "fastify": "^4",
    "graphql": "^16",
    "graphql-yoga": "^5",
    "pg": "^8"
  },
  "devDependencies": {
    "@types/node": "^20",
    "@types/pg": "^8",
    "prisma": "^7.8.0",
    "ts-node": "^10",
    "tsx": "^4.20.6",
    "typescript": "^5",
    "vitest": "^4.1.9"
  },
  "allowScripts": {
    "@prisma/engines@7.8.0": true,
    "prisma@7.8.0": true,
    "esbuild@0.28.1": true
  }
}
